{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ctx.rs/plugins/plugin-manifest.v1.schema.json",
  "title": "PluginManifest",
  "description": "ctx plugin manifest schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version"],
  "allOf": [
    {
      "anyOf": [
        {
          "required": ["entrypoints"],
          "properties": {
            "entrypoints": {
              "minItems": 1
            }
          }
        },
        {
          "required": ["contributes"],
          "properties": {
            "contributes": {
              "$ref": "#/$defs/NonEmptyPluginContributions"
            }
          }
        }
      ]
    }
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "default": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"]
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PluginEntrypoint"
      },
      "default": []
    },
    "contributes": {
      "$ref": "#/$defs/PluginContributions"
    },
    "compatibility": {
      "$ref": "#/$defs/PluginCompatibility"
    }
  },
  "$defs": {
    "StringArray": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "Environment": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "PluginEntrypointKind": {
      "type": "string",
      "enum": ["process", "worker", "webview"]
    },
    "PluginEntrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/PluginEntrypointKind",
          "default": "process"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "$ref": "#/$defs/StringArray"
        },
        "cwd": {
          "type": ["string", "null"]
        },
        "environment": {
          "$ref": "#/$defs/Environment"
        }
      }
    },
    "PluginProviderContribution": {
      "$ref": "#/$defs/NamedPluginContribution"
    },
    "PluginRuntimeContribution": {
      "$ref": "#/$defs/NamedPluginContribution"
    },
    "PluginCommandContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "category": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        }
      }
    },
    "PluginCollectorContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        },
        "events": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "PluginObserverContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        },
        "events": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "PluginUiSurfaceKind": {
      "type": "string",
      "enum": ["panel", "sidebar", "status_bar", "command_palette", "settings"]
    },
    "PluginUiSurfaceContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "surface"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "$ref": "#/$defs/PluginUiSurfaceKind"
        },
        "description": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        },
        "contexts": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "NamedPluginContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        },
        "capabilities": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "PluginContributions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginProviderContribution"
          },
          "default": []
        },
        "runtimes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginRuntimeContribution"
          },
          "default": []
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginCommandContribution"
          },
          "default": []
        },
        "collectors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginCollectorContribution"
          },
          "default": []
        },
        "observers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginObserverContribution"
          },
          "default": []
        },
        "ui_surfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginUiSurfaceContribution"
          },
          "default": []
        },
        "templates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginWorkbenchTemplateContribution"
          },
          "default": []
        },
        "toolbar_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginWorkbenchToolbarActionContribution"
          },
          "default": []
        },
        "artifact_renderers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginArtifactRendererContribution"
          },
          "default": []
        },
        "card_renderers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginWorkbenchCardRendererContribution"
          },
          "default": []
        },
        "detail_sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginWorkbenchSectionContribution"
          },
          "default": []
        },
        "review_sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginWorkbenchSectionContribution"
          },
          "default": []
        }
      },
      "default": {}
    },
    "NonEmptyPluginContributions": {
      "allOf": [
        {
          "$ref": "#/$defs/PluginContributions"
        },
        {
          "anyOf": [
            {
              "required": ["providers"],
              "properties": {
                "providers": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["runtimes"],
              "properties": {
                "runtimes": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["commands"],
              "properties": {
                "commands": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["collectors"],
              "properties": {
                "collectors": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["observers"],
              "properties": {
                "observers": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["ui_surfaces"],
              "properties": {
                "ui_surfaces": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["templates"],
              "properties": {
                "templates": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["toolbar_actions"],
              "properties": {
                "toolbar_actions": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["artifact_renderers"],
              "properties": {
                "artifact_renderers": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["card_renderers"],
              "properties": {
                "card_renderers": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["detail_sections"],
              "properties": {
                "detail_sections": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["review_sections"],
              "properties": {
                "review_sections": {
                  "minItems": 1
                }
              }
            }
          ]
        }
      ]
    },
    "PluginDeclarativeWorkbenchContribution": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "contexts": {
          "$ref": "#/$defs/StringArray"
        },
        "data_sources": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "PluginWorkbenchTemplateContribution": {
      "allOf": [
        {
          "$ref": "#/$defs/PluginDeclarativeWorkbenchContribution"
        },
        {
          "type": "object",
          "required": ["title", "template"],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "template": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "ApprovedCtxActionId": {
      "type": "string",
      "enum": [
        "work.focus",
        "task.start",
        "ctx.command.run",
        "plugin.command.run",
        "work.export_redact",
        "artifact.attach",
        "note.attest",
        "gate.update",
        "provider.settings.open",
        "provider.session.restart"
      ]
    },
    "PluginWorkbenchToolbarActionContribution": {
      "allOf": [
        {
          "$ref": "#/$defs/PluginDeclarativeWorkbenchContribution"
        },
        {
          "type": "object",
          "required": ["title"],
          "anyOf": [
            {
              "required": ["command"]
            },
            {
              "required": ["action"]
            }
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "command": {
              "type": "string",
              "minLength": 1
            },
            "action": {
              "$ref": "#/$defs/ApprovedCtxActionId"
            },
            "icon": {
              "type": ["string", "null"]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "PluginArtifactRendererContribution": {
      "allOf": [
        {
          "$ref": "#/$defs/PluginDeclarativeWorkbenchContribution"
        },
        {
          "type": "object",
          "required": ["artifact_types", "renderer"],
          "properties": {
            "artifact_types": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "renderer": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "PluginWorkbenchCardRendererContribution": {
      "allOf": [
        {
          "$ref": "#/$defs/PluginDeclarativeWorkbenchContribution"
        },
        {
          "type": "object",
          "required": ["card", "renderer"],
          "properties": {
            "card": {
              "type": "string",
              "minLength": 1
            },
            "renderer": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "PluginWorkbenchSectionContribution": {
      "allOf": [
        {
          "$ref": "#/$defs/PluginDeclarativeWorkbenchContribution"
        },
        {
          "type": "object",
          "required": ["section", "renderer"],
          "properties": {
            "section": {
              "type": "string",
              "minLength": 1
            },
            "renderer": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "PluginCompatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_ctx_version": {
          "type": ["string", "null"]
        },
        "capabilities": {
          "$ref": "#/$defs/StringArray"
        }
      },
      "default": {}
    }
  }
}
