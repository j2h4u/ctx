{
  "name": "@ctx/plugin-sdk",
  "version": "0.1.0",
  "description": "Typed helpers for repo-local ctx plugin manifests.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsbuildinfo/plugin-sdk.tsbuildinfo",
    "test": "pnpm run build && node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
